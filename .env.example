# Path to your music library on the host machine
MUSIC_PATH=C:\Users\AXIOM\Music

# Port to bind the web interface on the host machine
WEB_PORT=8000

# IP address to bind to (set to 127.0.0.1 if using reverse proxy locally)
WEB_BIND=0.0.0.0

# Disable the built-in single-password gate (only safe behind proxy auth)
AUTH_DISABLED=false

# Override Docker network configurations if needed
# DOCKER_NETWORK=tuneforge-net
# DOCKER_NETWORK_EXTERNAL=false
